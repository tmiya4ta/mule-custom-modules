<mule xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xmlns:jpcharactersconverter="http://www.mulesoft.org/schema/mule/jpcharactersconverter"
      xsi:schemaLocation="http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
          http://www.mulesoft.org/schema/mule/jpcharactersconverter http://www.mulesoft.org/schema/mule/jpcharactersconverter/current/mule-jpcharactersconverter.xsd">

    <jpcharactersconverter:config name="config" />

    <flow name="hankakuToZenkakuFlow">
        <jpcharactersconverter:hankaku-to-zenkaku inputText="ABC 123 ｶﾀｶﾅ"/>
    </flow>

    <flow name="zenkakuToHankakuFlow">
        <jpcharactersconverter:zenkaku-to-hankaku inputText="ＡＢＣ　１２３　カタカナ"/>
    </flow>

</mule>
