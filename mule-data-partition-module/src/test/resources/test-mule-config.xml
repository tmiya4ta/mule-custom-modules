<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:datapartition="http://www.mulesoft.org/schema/mule/datapartition"
      xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
                           http://www.mulesoft.org/schema/mule/datapartition http://www.mulesoft.org/schema/mule/datapartition/current/mule-datapartition.xsd">

  <datapartition:config name="config" />

  <!-- CSV partition: 1KB partitions for testing -->
  <flow name="partition-csv-1kb">
    <datapartition:partition-csv config-ref="config"
                                 partitionSize="1"
                                 sizeUnit="KB"
                                 includeHeader="true" />
  </flow>

  <flow name="partition-csv-1kb-no-header">
    <datapartition:partition-csv config-ref="config"
                                 partitionSize="1"
                                 sizeUnit="KB"
                                 includeHeader="false" />
  </flow>

  <flow name="partition-csv-10kb">
    <datapartition:partition-csv config-ref="config"
                                 partitionSize="10"
                                 sizeUnit="KB"
                                 includeHeader="true" />
  </flow>

  <!-- JSON partition: 1KB partitions for testing -->
  <flow name="partition-json-1kb">
    <datapartition:partition-json config-ref="config"
                                  partitionSize="1"
                                  sizeUnit="KB" />
  </flow>

  <flow name="partition-json-5kb">
    <datapartition:partition-json config-ref="config"
                                  partitionSize="5"
                                  sizeUnit="KB" />
  </flow>

</mule>
